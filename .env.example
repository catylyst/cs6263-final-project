# Copy this file to .env before running the project.
# .env is gitignored. Never commit real secrets.

# Adaptive RAG local configuration
# This project does not require Anthropic, OpenAI, HuggingFace, or any paid external LLM API key.

# REQUIRED — application environment.
APP_ENV=local

# REQUIRED — local JSONL corpus used by the retriever.
CORPUS_PATH=data/corpus.jsonl

# OPTIONAL — log level. INFO by default. DEBUG for verbose tracing.
LOG_LEVEL=INFO

# OPTIONAL — application port. Default 8080. The TA expects 8080.
APP_PORT=8080

# OPTIONAL — maximum accepted query length.
MAX_QUERY_CHARS=1000

# OPTIONAL — default number of retrieved passages for retrieval-based strategies.
DEFAULT_TOP_K=5

# OPTIONAL — maximum number of retrieval rounds for multi-step retrieval.
MAX_MULTI_STEP_ROUNDS=2

# OPTIONAL — enable debug behavior during local development.
ENABLE_DEBUG=false